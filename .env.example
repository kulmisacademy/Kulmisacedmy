# Neon PostgreSQL – get your connection string from https://console.neon.tech
# Click your project → Connect → copy the connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DATABASE?sslmode=require"

# Optional: used by db:seed and db:ensure-admin to create/update admin user
ADMIN_EMAIL=admin@kulmis.academy
ADMIN_PASSWORD=Admin123!

# Required for admin session cookie (use a long random string in production)
SESSION_SECRET=your-session-secret-min-32-characters-long

# Required on Vercel for course thumbnail uploads (filesystem is read-only). Optional locally.
# Vercel: Project → Storage → Blob → Create → copy token; add as env var BLOB_READ_WRITE_TOKEN
# BLOB_READ_WRITE_TOKEN=

# Base URL for password reset links (e.g. https://kulmis.academy or http://localhost:3000)
# SITE_URL=https://kulmis.academy

# Optional: SMTP for sending emails (e.g. enrollment, payment confirmation)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM="Kulmis Academy <your-email@gmail.com>"
